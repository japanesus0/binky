<?xml version="1.0" encoding="utf-8"?>
<!--
  Tells Android's resource shrinker (enabled via `isShrinkResources = true`
  in app/build.gradle.kts) to preserve our notification-sound WAV.
  Without this, R8 strips the file because it can't see the runtime
  reference (the plugin looks up `R.raw.elle_and_lorelei` via the string
  "elle_and_lorelei" from Dart code), and OS notifications fail with:
    PlatformException(invalid_sound, The resource elle_and_lorelei could
    not be found...)
-->
<resources xmlns:tools="http://schemas.android.com/tools"
    tools:keep="@raw/elle_and_lorelei" />
